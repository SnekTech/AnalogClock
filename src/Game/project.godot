;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="AnalogClock"
run/main_scene="uid://ddeqm380rgljy"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="uid://bdohtig5mdd7l"

[autoload]

GTweensGodotUpdater="*res://Scripts/Autoload/GTweensGodotUpdater.cs"

[display]

window/size/viewport_width=360
window/size/viewport_height=360
window/size/borderless=true
window/size/always_on_top=true
window/size/transparent=true
window/stretch/mode="canvas_items"
window/per_pixel_transparency/allowed=true

[dotnet]

project/assembly_name="AnalogClock"
project/solution_directory="../.."

[editor]

naming/scene_name_casing=1

[gui]

theme/custom_font="uid://difupo4cr2615"

[input]

